@using BV411.Models.main
@model Basket

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Main</title>
    <link rel="stylesheet" href="~/css/bascet/style.css">
</head>
<body>
    <div class="content">
        @foreach(var prod in Model.Products)
        {
            <div class="border"></div>
            <span class="product">@prod.product.Name</span>
            <a href="https://localhost:7213/basket/delete?id=0&ip=@prod.product.Id"> удалить</a>
            <p>@prod.count</p>
        }
    </div>
    <div class="prise">
        <div>
            <h3>Итог:</h3>
            <h2>@Model.prise</h2>
        </div>
        <button>оплатить</button>
        <a href="https://localhost:7213/basket/clear?id=0">очистить корзину</a>
    </div>
</body>
</html>