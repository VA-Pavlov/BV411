@model List<Order>

<link rel="stylesheet" href="~/css/OrderSite.css"/>

<h2>Мои заказы</h2>

@if(Model.Count==0)
{
    <h3 style="text-align:center;margin-top:70px">
        У вас пока нет заказов
    </h3>
}
else
{
    <div class="orders">

        @foreach(var order in Model)
        {
            <div class="order-card">

                <h3>Заказ №@order.Id</h3>

                <p>
                    📅 @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </p>

                <p>
                    📦 Товаров:
                    @order.Items.Sum(x=>x.Quantity)
                </p>

                <p>
                    💰
                    @order.TotalPrice.ToString("N0")
                    ₽
                </p>

                <p>
                    Статус:
                    <b>@order.Status</b>
                </p>

                <button
                    onclick="location.href='/Order/Details/@order.Id'">

                    Подробнее

                </button>

            </div>
        }

    </div>
}