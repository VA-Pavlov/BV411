@model BV411.Models.User
@using BV411.Models

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Профиль</title>
    <link rel="stylesheet" href="~/css/ProfileSite.css">
</head>

<body>

    <main>

        <h2>Профиль пользователя</h2>

        <div class="products">

            <div class="card" style="text-align:center">

                <div class="product-image">
                    @if (!string.IsNullOrEmpty(Model.Avatar))
                    {
                        <img src="@Model.Avatar" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span>👤</span>
                    }
                </div>

                <h3>@Model.Login</h3>

                <p>Email: @Model.Email</p>
                <p>Телефон: @Model.Phone</p>

                <button onclick="location.href='/Profile/Edit'">
                    Редактировать профиль
                </button>

                <button onclick="location.href='/Profile/Logout'">
                    Выйти
                </button>

            </div>

        </div>

    </main>

    <footer>
        <div class="footer-bottom">
            © 2026 Барахолка
        </div>
    </footer>

</body>
</html>