<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Барахолка</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <header>
        <a href="#" class="logo-btn">Барахолка</a>

        <section class="search-section">
            <input type="text" placeholder="Поиск товаров...">
            <button>Найти</button>
        </section>
        <div class="buttons">
            <button>Каталог</button>
            <button>Избранное</button>
            <button>Корзина</button>
            <button>Профиль</button>
        </div>
    </header>

    @if (ViewContext.RouteData.Values["action"]?.ToString() == "Index")
    {
        <section class="hero">
            <h1>Добро пожаловать на Барахолку</h1>
            <p>100% легально и 100% не из Escape From Tarkov</p>
            <button>Перейти в каталог</button>
        </section>
    }

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="footer-content">

            <div>
                <h3>Барахолка</h3>
                <p>Площадка для покупки и продажи товаров.</p>
            </div>

            <div>
                <h3>Контакты</h3>
                <p>Email: support@baraholka.ru</p>
                <p>Телефон: +8 (800) 555-35-35</p>
            </div>

            <div>
                <h3>Информация</h3>
                <p>Пользовательское соглашение</p>
                <p>Политика конфиденциальности</p>
            </div>

        </div>

        <div class="footer-bottom">
            © 2026 Барахолка. Все права защищены.
        </div>

    </footer>

</body>

</html>