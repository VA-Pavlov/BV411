<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BV411</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BV411.styles.css" asp-append-version="true" />
</head>
<body>
    <header>

        <h1>POLKA</h1>
        <div>
            <a href="https://localhost:7213/">главная</a>
            <a href="https://localhost:7213/basket/index/0">корзина</a>
            <a href="">избраное</a>
            <a href="">аккаунт</a>
            <img src="https://yt3.googleusercontent.com/1qo08AhHQ3QHPNXcsukq679I5HWZp4IZQkvqK-r3AahOOWvFmEAFBCWKYd3F2JjSkTKWoDQv-g=s900-c-k-c0x00ffffff-no-rj" alt="">

        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
