<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Книжный магазин - Хедер и Футер</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>

    <!-- ========== HEADER ========== -->
    <header class="header">
        <div class="container header__container">
            <div class="logo">
                <a href="/" class="logo__link">BookStore</a>
            </div>

            <nav class="nav">
                <ul class="nav__list">
                    <li class="nav__item">
                        <a href="/favorites" class="nav__link">
                            <svg class="nav__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
                            </svg>
                            <span>Любимые товары</span>
                        </a>
                    </li>
                    <li class="nav__item">
                        <a href="/cart" class="nav__link">
                            <svg class="nav__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="9" cy="21" r="1" />
                                <circle cx="20" cy="21" r="1" />
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                            </svg>
                            <span>Корзина</span>
                            <span class="nav__badge">0</span>
                        </a>
                    </li>
                    <li class="nav__item">
                        <a href="/account" class="nav__link nav__link--highlight">
                            <svg class="nav__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <span>Аккаунт</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Мобильное меню (бургер) -->
            <button class="burger" aria-label="Открыть меню">
                <span class="burger__line"></span>
                <span class="burger__line"></span>
                <span class="burger__line"></span>
            </button>
        </div>
    </header>

    <!-- Основной контент страницы (пример) -->
    <main class="main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="footer">
        <div class="container footer__container">
            <div class="footer__column">
                <h3 class="footer__title">BookStore</h3>
                <p class="footer__about">
                    Книжный магазин с лучшим ассортиментом. Доставка по всей стране.
                </p>
                <div class="footer__socials">
                    <a href="#" class="footer__social-link" aria-label="VK">VK</a>
                    <a href="#" class="footer__social-link" aria-label="Telegram">TG</a>
                    <a href="#" class="footer__social-link" aria-label="Instagram">IG</a>
                </div>
            </div>

            <div class="footer__column">
                <h4 class="footer__subtitle">Покупателям</h4>
                <ul class="footer__list">
                    <li><a href="#">Доставка и оплата</a></li>
                    <li><a href="#">Возврат</a></li>
                    <li><a href="#">Бонусная программа</a></li>
                    <li><a href="#">Подарочные сертификаты</a></li>
                </ul>
            </div>

            <div class="footer__column">
                <h4 class="footer__subtitle">О магазине</h4>
                <ul class="footer__list">
                    <li><a href="#">О нас</a></li>
                    <li><a href="#">Контакты</a></li>
                    <li><a href="#">Вакансии</a></li>
                    <li><a href="#">Партнёрам</a></li>
                </ul>
            </div>

            <div class="footer__column">
                <h4 class="footer__subtitle">Контакты</h4>
                <ul class="footer__list">
                    <li>📞 <a href="tel:+78005553535">8 (800) 555-35-35</a></li>
                    <li>✉️ <a href="mailto:info@bookstore.ru">info@bookstore.ru</a></li>
                    <li>📍 г. Москва, ул. Книжная, 15</li>
                </ul>
            </div>
        </div>

        <div class="footer__bottom">
            <div class="container footer__bottom-container">
                <p>&copy; 2026 BookStore. Все права защищены.</p>
                <div class="footer__legal">
                    <a href="#">Политика конфиденциальности</a>
                    <a href="#">Пользовательское соглашение</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Простой скрипт для бургер-меню (для мобильной версии)
        const burger = document.querySelector('.burger');
        const nav = document.querySelector('.nav');

        if (burger && nav) {
            burger.addEventListener('click', () => {
                nav.classList.toggle('nav--active');
                burger.classList.toggle('burger--active');
            });
        }
    </script>
</body>
</html>
