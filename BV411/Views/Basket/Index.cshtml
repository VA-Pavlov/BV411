@model Basket
@using Microsoft.AspNetCore.Http
@using BV411.Models
<link rel="stylesheet" href="~/css/BasketSite.css">
@{
    int? userId = Context.Session.GetInt32("UserId");

    Favorite favorite = new Favorite();

    if (userId != null)
    {
        favorite = FavoriteRepos.GetFavorite(userId.Value);
    }
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Корзина</title>
    <link rel="stylesheet" href="~/css/BasketSite.css">
</head>
<body>


    <main>

        <h2>Корзина</h2>

        <div class="products">

            @foreach (var group in Model.Products.GroupBy(x => x.Id).OrderBy(g => g.First().Name))
            {
                var product = group.First();
                var quantity = group.Count();

                <div class="card">

                    @if (userId == null)
                    {
                        <button class="favorite"
                                onclick="location.href='/Account/Auth'">
                            ☆
                        </button>
                    }
                    else
                    {
                        bool isFavorite = favorite.Products.Any(x => x.Id == product.Id);

                        <button class="favorite @(isFavorite ? "active" : "")"
                                onclick="location.href='/Favorite/Toggle?id=@product.Id'">
                            @(isFavorite ? "★" : "☆")
                        </button>
                    }

                    <div class="product-image">
                        Фото товара
                    </div>

                    <h3>
                        <a asp-controller="Product"
                           asp-action="Info"
                           asp-route-id="@product.Id"
                           class="product-link">
                            @product.Name
                        </a>
                    </h3>

                    <p>Цена: @product.Price.ToString("N0") ₽</p>

                    @{
                        var totalPrice = product.Price * quantity;
                    }

                    <p>Стоимость: @totalPrice.ToString("N0") ₽</p>

                    <div class="quantity-controls">

                        <button onclick="location.href='/Basket/Minus?basketId=@Model.Id&id=@product.Id'">
                            -
                        </button>

                        <span class="quantity-count">
                            @quantity
                        </span>

                        <button onclick="location.href='/Basket/Add?basketId=@Model.Id&id=@product.Id'">
                            +
                        </button>

                    </div>

                    <button class="remove-btn"
                            onclick="location.href='/Basket/Remove?basketId=@Model.Id&id=@product.Id'">
                        Удалить товар полностью
                    </button>

                </div>
            }

        </div>

        <div class="cart-summary">

            <h3>Итого: @Model.Price.ToString("N0") ₽</h3>
            <h3>Товаров: @Model.Count</h3>

            <div class="cart-buttons">

                <button class="back-btn"
                        onclick="location.href='/Product/Index'">
                    Вернуться к покупкам
                </button>

                <button class="checkout-btn" 
                onclick="location.href='/Order/CreateFromBasket'">
                    Оформить заказ
                </button>

                <button class="clear-btn"
                        onclick="location.href='/Basket/Clear?basketId=@Model.Id'">
                    Очистить корзину
                </button>

            </div>

        </div>

    </main>
</body>
</html>