@model List<Product>
@{
    var favorite = FavoriteRepos.GetFavorite();
}
<div class="products">

    @foreach (var product in Model)
    {
        <div class="card">

            <button class="favorite @(favorite.Products.Any(x => x.Id == product.Id) ? "active" : "")"
                    onclick="location.href='/Favorite/Toggle?id=@product.Id'">
                @(favorite.Products.Any(x => x.Id == product.Id) ? "★" : "☆")
            </button>

            <div class="product-image">
                Фото товара
            </div>

            <h3>
                <a asp-controller="Product"
                   asp-action="Info"
                   asp-route-id="@product.Id"
                   class="product-link">
                    @product.Name
                </a>
            </h3>

            <p>@product.Price.ToString("N0") ₽</p>

            <button onclick="location.href='/Basket/Add/@product.Id'">
                Добавить в корзину
            </button>
            <button>Купить</button>

        </div>
    }

</div>